{
  "name": "pi-vim",
  "version": "0.12.1",
  "description": "Vim-style modal editing for Pi's TUI editor",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "vim",
    "editor"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lajarre/pi-vim.git"
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo 'nothing to build'",
    "format": "biome check --write .",
    "lint": "biome check . && eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/",
    "test:nvim": "bun test ./test/nvim-parity.ts ./test/nvim-parity-*.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "pack:check": "node --import tsx/esm script/pack-check.ts",
    "hooks:install": "lefthook install",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run pack:check && npm test"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.7.2",
    "bun-types": "^1.3.14",
    "eslint": "^9.25.1",
    "lefthook": "^2.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.31.1"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*",
    "@oh-my-pi/pi-tui": ">=16.5.2"
  }
}
